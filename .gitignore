# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Kiro specs (local IDE config)
.kiro/

# Qodo
.qodo/

# Local memory artifacts (generated by intelligence engine)
# AGENT_PREFERENCES.md is whitelisted because it is a shared, persistent
# preferences file that should be tracked across machines.
memory/*
!memory/AGENT_PREFERENCES.md

# Freebuff Desktop app local state (desktop.db is an app-private SQLite
# database the assistant writes at runtime; never track it)
.freebuff/

# Generated code-graph data (emitted by scripts/code-graph.ps1). Regenerate
# locally with the script; do not commit the JSON output.
docs/wiki/_data/

# mkdocs build output (regenerated by .github/workflows/wiki-pages.yml;
# do not commit the rendered HTML — the gh-pages branch is the published copy).
# Anchored to repo root so future `docs/site/` or `scripts/site/` folders are
# not silently swallowed.
/site/

# Backups
backups/

# Logs
logs/

# Temporary fix scripts
_fix.ps1

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Release packages on-repo for direct download (see release/SHA256SUMS.txt).
# Each release adds ~134 KB of binary blob; switch release/*.zip to Git LFS
# once release history exceeds 2 MB or 15 retained versions.
*.zip
!release/*.zip
